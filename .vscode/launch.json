    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Run Task Tests",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/tests/TaskTest.py",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Run Sound Helper Tests",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/tests/SoundHelperTest.py",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Run Config Helper Tests",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/tests/ConfigHelperTest.py",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "cwd": "${workspaceFolder}"
        }
    ]
}